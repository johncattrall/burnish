{
  "name": "burnish",
  "version": "1.0.0",
  "description": "An Obsidian plugin that polishes your notes with an LLM, with a diff preview before anything is written.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node --test \"tests/*.test.ts\"",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "llm",
    "anthropic",
    "openai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "diff": "^9.0.0"
  }
}
